{
  "name": "@trip-map/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "geo:verify-sources": "node ./scripts/geo/verify-source-catalog.mjs",
    "geo:build": "node ./scripts/geo/build-geometry-manifest.mjs",
    "geo:build:check": "node ./scripts/geo/build-geometry-manifest.mjs --dry-run --output-root .tmp/geo-build-check"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@trip-map/contracts": "workspace:*",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "d3-geo": "^3.1.1",
    "leaflet": "^1.9.4",
    "nanoid": "^5.1.9",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^4"
  },
  "devDependencies": {
    "@fontsource-variable/nunito": "^5.2.7",
    "@tailwindcss/vite": "^4.2.2",
    "@types/d3-geo": "^3.1.0",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "gcoord": "^1.0.7",
    "happy-dom": "^20.9.0",
    "i18n-iso-countries": "^7.14.0",
    "tailwindcss": "^4.2.2",
    "topojson-client": "^3.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6",
    "world-atlas": "^2.0.2"
  }
}
